      {
        "parameters": {
          "jsCode": "const data = $input.first().json;\nconst content = data.body.content;\n\nconst fullText = content\n  .filter(block => block.paragraph)\n  .flatMap(block => block.paragraph.elements)\n  .map(el => el.textRun?.content || '')\n  .join('');\n\nconst endIndex = content[content.length - 1].endIndex - 1;\n\nreturn [{ json: { \n  fullText, \n  endIndex, \n  documentId: data.documentId \n}}];"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          -96,
          -96
        ],
        "id": "6f2d11da-35e4-4de9-9014-9f75d092ce40",
        "name": "doc_info"
      },
      {
        "parameters": {
          "jsCode": "const documentId = $('Подпрограмма').first().json.doc_id;\nconst endIndex = $('doc_info').first().json.endIndex;\nconst newText = $input.first().json.text;\n\nconst body = {\n  requests: [\n    {\n      deleteContentRange: {\n        range: {\n          startIndex: 1,\n          endIndex: endIndex\n        }\n      }\n    },\n    {\n      insertText: {\n        location: { index: 1 },\n        text: newText\n      }\n    }\n  ]\n};\n\nreturn [{ json: { documentId, body } }];\n"
        },

  "name": "Пользователи и приложения",
  "nodes": [
    {
      "parameters": {
        "content": "## Приложения пользователя\nТаблица app в схеме public\napp_id - идентификатор\napp_name - название приложения (не уникальное, не пустое)\napp_password - пароль пользователя для этого приложения\napp_user_id - связь с пользователем\napp_mode - режим работы (\"test\"/другое) для настройки webhook (NOOL)\napp_base_url -  базовый адрес  сервера (https://n8n.avdivo.ru/)\napp_timezone - таймзона,  по умолчанию 3 (это UTC+3)",
        "height": 224,
        "width": 496
      },
      "type": "n8n-nodes-base.stickyNote",

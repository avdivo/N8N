    },
    {
      "parameters": {
        "content": "## Пользователи в БД\nТаблица user в схеме public\nuser_id - идентификатор\nuser_login - логин и название схемы в БД (уникальный)\nuser_fio - фамилия, имя, отчество (не обязательный)\nuser_email - адрес электронной почты (уникальный, не обязательный)\nuser_phone - телефон (уникальный, не обязательный)\nuser_telegram - уникальный (уникальный, обязательный)\n",
        "height": 224,
        "width": 496
      },
      "type": "n8n-nodes-base.stickyNote",
      "position": [
        0,
        0
      ],
      "typeVersion": 1,

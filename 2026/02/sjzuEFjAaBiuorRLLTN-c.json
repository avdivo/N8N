    {
      "parameters": {
        "operation": "executeQuery",
        "query": "-- Таблица пользователей\nCREATE TABLE IF NOT EXISTS public.user (\n    user_id SERIAL PRIMARY KEY,\n    user_login TEXT NOT NULL UNIQUE,\n    user_fio TEXT,\n    user_email TEXT UNIQUE,\n    user_phone TEXT UNIQUE,\n    user_telegram TEXT NOT NULL UNIQUE\n);\n\n-- Таблица приложений пользователя\nCREATE TABLE IF NOT EXISTS public.app (\n    app_id SERIAL PRIMARY KEY,\n    app_name TEXT NOT NULL UNIQUE,\n    app_password TEXT NOT NULL,\n    app_user_id INTEGER NOT NULL,\n    app_mode TEXT DEFAULT 'test',\n    app_base_url TEXT DEFAULT 'https://n8n.avdivo.ru/',\n    app_timezone INTEGER DEFAULT 3,\n    CONSTRAINT fk_app_user FOREIGN KEY (app_user_id)\n        REFERENCES public.user(user_id)\n        ON DELETE CASCADE\n);\n",
        "options": {}
      },

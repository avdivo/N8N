      "parameters": {
        "jsCode": "// 1. Получаем массив всех админов из конкретной ноды\nconst adminsArray = $('Все админы канала').all();\n\n// 2. Получаем данные о канале из триггерной ноды\nconst channelInfo = $('Бот назначен Админом канала').first().json.my_chat_member;\n\n// 3. Собираем ID только людей (не ботов)\nconst adminIds = adminsArray\n  .filter(item => !item.json.user.is_bot)\n  .map(item => item.json.user.id);\n\n// 4. Итоговый объект для Postgres\nreturn {\n  channel_name: channelInfo.chat.title,\n  channel_id: channelInfo.chat.id,\n  admins: JSON.stringify(adminIds)\n};\n"

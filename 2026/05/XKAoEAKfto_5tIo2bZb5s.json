    {
      "parameters": {
        "jsCode": "function getNodeData(nodeName) {\n  try {\n    const items = $(nodeName).all();\n    if (!items || items.length === 0) return null;\n    return items[0].json; // берем чистый первый элемент\n  } catch (e) {\n    return null;\n  }\n}\n\n// 1. Сбор данных\nconst userCheck = getNodeData('Проверка блокировки пользователя');\nconst userNotSent = getNodeData('Пользователь не передан');\nconst channelCheck = getNodeData('Проверка блокировки канала');\nconst channelNotSent = getNodeData('Канал не передан');\n\nlet userStatus = null;\nlet channelStatus = null;\nlet adminStatus = null;\nlet reports = [];\nlet needTelegramCheck = false;\n\n// --- АНАЛИЗ ПОЛЬЗОВАТЕЛЯ ---\n// Если в ноде \"Пользователь не передан\" есть данные или в БД пусто по всем фронтам\nif (userNotSent && Object.keys(userNotSent).length > 0) {\n  userStatus = null;\n} else if (!userCheck || Object.keys(userCheck).length === 0) {\n  userStatus = null; // Пользователь передан, но не найден в БД -> null\n} else if (userCheck.user_blocked === true) {\n  userStatus = false;\n  reports.push(\"Пользователь не имеет прав на это действие\");\n} else if (userCheck.user_blocked === false || userCheck.user_exists === true) {\n  userStatus = true;\n}\n\n// --- АНАЛИЗ КАНАЛА ---\nif (channelNotSent && Object.keys(channelNotSent).length > 0) {\n  channelStatus = null;\n} else if (!channelCheck || Object.keys(channelCheck).length === 0) {\n  channelStatus = null; // Канал передан, но не найден в БД -> null\n} else if (channelCheck.channel_blocked === true) {\n  channelStatus = false;\n  reports.push(\"Канал заблокирован\");\n} else if (channelCheck.channel_blocked === false || channelCheck.channel_exists === true) {\n  channelStatus = true;\n}\n\n// --- ОПРЕДЕЛЕНИЕ СТАТУСА АДМИНА И НЕОБХОДИМОСТИ ТГ ---\nif (userStatus === true && channelStatus === true) {\n  needTelegramCheck = true; \n} else if (userStatus === false || channelStatus === false) {\n  adminStatus = false;\n  reports.push(\"Пользователь не является администратором канала\");\n} else {\n  adminStatus = null;\n}\n\n// --- ВЫЧИСЛЕНИЕ РЕЗУЛЬТАТА (ЛОГИЧЕСКОЕ И) ---\nlet resultStatus = null;\nif (userStatus === false || channelStatus === false || adminStatus === false) {\n  resultStatus = false;\n} else if (userStatus === true && channelStatus === true && adminStatus === true) {\n  resultStatus = true;\n} else {\n  resultStatus = null;\n}\n\nreturn [{\n  json: {\n    user: userStatus,\n    channel: channelStatus,\n    admin: adminStatus,\n    result: resultStatus,\n    report: reports.length > 0 ? reports.join(\", \") : null,\n    _need_tg_check: needTelegramCheck\n  }\n}];\n"
      },

        "id": "6754cc6d-bda6-4ed0-9e6d-a6461ea0c810",
        "name": "Активные кампании"
      },
      {
        "parameters": {
          "operation": "executeQuery",
          "query": "WITH input_ids AS (\n  SELECT unnest(ARRAY[\n    {{ \"'\" + $input.all().map(i => i.json.campaign_id).join(\"','\") + \"'\" }}\n  ])::VARCHAR AS campaign_id\n)\nSELECT DISTINCT i.campaign_id\nFROM input_ids i\nLEFT JOIN \"{{ $(\"Определение клиента\").first().json.scheme_name }}\".daily_spends d\n  ON i.campaign_id = d.campaign_id\n  /* Приводим время сервера к вашему поясу перед получением даты */\n  AND d.date = (NOW() AT TIME ZONE 'Europe/Moscow')::DATE\nWHERE d.campaign_id IS NULL\n",
          "options": {}
        },
        "type": "n8n-nodes-base.postgres",
        "typeVersion": 2.6,

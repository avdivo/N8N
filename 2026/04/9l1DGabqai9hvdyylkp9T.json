            "name": "Postgres account"
          }
        }
      },
      {
        "parameters": {
          "content": "Получает все активные кампании и определяет id кампаний, которых нет в таблице с текущей датой",
          "height": 96,
          "width": 272
        },
        "type": "n8n-nodes-base.stickyNote",

        "disabled": true
      },
      {
        "parameters": {
          "jsCode": "// Получаем список ID, которых нет в базе (из входящих данных текущей ноды)\nconst missingIds = $input.all().map(i => i.json.campaign_id);\n\n// Получаем полный список активных кампаний\nconst activeCampaigns = $(\"Активные кампании\").all();\n\n// Фильтруем активные кампании, оставляя только те, чьи ID есть в списке missingIds\nconst result = activeCampaigns\n  .filter(item => missingIds.includes(item.json.campaign_id))\n  .map(item => {\n    return {\n      json: {\n        campaign_id: item.json.campaign_id,\n        campaign_name: item.json.campaign_name,\n        advertising_platform: item.json.advertising_platform,\n        spend: item.json.daily_budget // daily_budget переходит в spend\n      }\n    };\n  });\n\nreturn result;\n"
        },

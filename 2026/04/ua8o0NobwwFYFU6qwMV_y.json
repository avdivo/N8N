          }
        },
        "type": "n8n-nodes-base.executeWorkflow",
        "typeVersion": 1.3,
        "position": [
          688,
          160
        ],
        "id": "380c6e89-e398-4957-bd7d-2666d6ee22c4",
        "name": "Расходы на кампании",
        "executeOnce": true
      },
      {
        "parameters": {
          "jsCode": "const leadsItems = $('Лидов по источникам').all();\nconst spendsItems = $('Расходы на кампании').all();\n\n// 1. Агрегация лидов\nlet leads_tiktok = 0;\nlet leads_ig = 0;\nlet leads_fb = 0;\nlet leads_no = 0;\n\nleadsItems.forEach(item => {\n    const src = (item.json.source_name || '').toLowerCase();\n    const count = parseInt(item.json.leads_count) || 0;\n\n    if (src.includes('tiktok')) {\n        leads_tiktok += count;\n    } else if (src.includes('ig') || src.includes('inst')) {\n        leads_ig += count;\n    } else if (src.includes('fb') || src.includes('face')) {\n        leads_fb += count;\n    } else {\n        leads_no += count;\n    }\n});\n\n// Сумма лидов для Меты и общая\nconst leads_meta = leads_ig + leads_fb;\nconst leads_total = leads_tiktok + leads_meta + leads_no;\n\n// 2. Агрегация расходов (сумма всех кампаний по платформе)\nlet spend_tiktok = 0;\nlet spend_meta = 0;\n\nspendsItems.forEach(item => {\n    const platform = (item.json.advertising_platform || '').toLowerCase();\n    const spend = parseFloat(item.json.total_spend) || 0;\n\n    if (platform === 'tiktok') {\n        spend_tiktok += spend;\n    } else if (platform === 'meta' || platform === 'facebook' || platform === 'instagram') {\n        spend_meta += spend;\n    }\n});\n\nconst spend_total = spend_tiktok + spend_meta;\n\n// 3. Расчет цены лида (с 2 знаками после запятой)\nconst calcPrice = (s, c) => c > 0 ? (s / c).toFixed(2) : \"0.00\";\n\nconst lead_price_tiktok = calcPrice(spend_tiktok, leads_tiktok);\nconst lead_price_meta = calcPrice(spend_meta, leads_meta);\nconst lead_price_all = calcPrice(spend_total, leads_total);\n\n// 4. Формирование отчета\nconst report = `*Тикток:* ${leads_tiktok}\n*Инстаграм:* ${leads_ig}\n*Фейсбук:* ${leads_fb}\n*Не определены:* ${leads_no}\n*Всего за сегодня:* ${leads_total}\n\n*Цена лида:* \n*Тикток:* ${lead_price_tiktok} руб.\n*Мета:* ${lead_price_meta} руб.\n*Общая:* ${lead_price_all} руб.`;\n\nreturn { report };\n"
        },

      },
      {
        "parameters": {
          "operation": "executeQuery",
          "query": "SELECT \n    COALESCE(NULLIF(source_name, ''), 'no_source') as source_name, \n    COUNT(*) as leads_count\nFROM \n    {{ $json.scheme_name }}.leads\nWHERE \n    (created_at AT TIME ZONE 'Europe/Moscow')::DATE BETWEEN '{{ $('Даты').item.json.from_date.replaceAll('.', '-') }}' AND '{{ $('Даты').item.json.to_date.replaceAll('.', '-') }}'\nGROUP BY \n    1\nORDER BY \n    leads_count DESC;\n",
          "options": {}
        },
        "type": "n8n-nodes-base.postgres",
